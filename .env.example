# App
APP_ENV=dev
LOG_LEVEL=INFO
API_PREFIX=/api/v1
ENABLE_LEGACY_ROUTES=true

# DB (preferred)
DATABASE_URL=mysql+pymysql://your_username:your_password@localhost:3306/your_database_name?charset=utf8mb4

# Legacy DB vars (optional fallback)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name
